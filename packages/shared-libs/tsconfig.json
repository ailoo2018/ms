{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",           // Changed from commonjs
    "moduleResolution": "NodeNext", // Added to handle ESM resolution
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}